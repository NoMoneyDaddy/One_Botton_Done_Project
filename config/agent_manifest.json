{
  "schema_version": "2.0.0",
  "agent_name": "one-button-done",
  "version": "2.0.0",
  "description": "Universal AI Agent Protocol — any AI platform, any model, autonomous delivery",
  "primary_entry": "AGENTS.md",
  "protocol_version": "v2-autonomous",
  "supported_surfaces": [
    "Claude Code",
    "Codex",
    "Cursor",
    "Windsurf",
    "Gemini CLI",
    "GitHub Copilot",
    "Roo Code",
    "Cline",
    "Aider",
    "Continue.dev",
    "ChatGPT",
    "GPT-4",
    "Hermes",
    "OpenClaw",
    "Mistral",
    "Llama",
    "Qwen",
    "DeepSeek",
    "Any LLM with markdown reading capability"
  ],
  "platform_entry_map": {
    "AGENTS.md": ["Codex", "Generic", "Any"],
    "CLAUDE.md": ["Claude Code"],
    "GEMINI.md": ["Gemini CLI"],
    ".cursorrules": ["Cursor"],
    ".windsurfrules": ["Windsurf"],
    ".clinerules": ["Roo Code", "Cline"],
    ".github/copilot-instructions.md": ["GitHub Copilot"],
    ".aider.conf.yml": ["Aider"],
    ".continuerc.json": ["Continue.dev"]
  },
  "skills_runtime_paths": [
    ".agents/skills",
    ".claude/skills",
    "skills"
  ],
  "autonomy_default_level": "L3",
  "autonomy_mode": "autonomous-delivery",
  "allowed_actions": [
    "repo_read",
    "repo_write_local",
    "doc_update",
    "dependency_install",
    "verified_tool_setup",
    "tech_stack_decision",
    "architecture_decision",
    "pr_create",
    "deployment_write"
  ],
  "stop_only_for": [
    "missing_credentials",
    "irreversible_destructive_operation",
    "billing_or_payment",
    "same_error_3x"
  ],
  "verification_gates": [
    "tests",
    "lint",
    "build",
    "smoke",
    "evidence_log"
  ],
  "audit_surfaces": [
    ".loop/STATE.json",
    ".loop/CHECKPOINTS.md",
    ".loop/EVIDENCE.md",
    ".loop/LEARNINGS.json",
    "docs/STATE.md",
    "docs/ADRS.md"
  ],
  "policy_matrix": "config/execution_policy_matrix.json",
  "learning_ledger": ".loop/LEARNINGS.json",
  "surface_manifest": "config/repo_surface_manifest.json",
  "capability_portability_matrix": "config/capability_portability_matrix.json",
  "session_task_schema": "config/session_task_schema.json",
  "task_bundle_schema": "config/task_bundle_schema.json",
  "official_doc_sources": "config/official_doc_sources.json",
  "platform_prerequisites": "config/platform_prerequisites.json",
  "secret_handling": "environment-variables-only",
  "delivery_protocol": {
    "phases": ["Understand", "Plan", "Build-Verify", "Ship"],
    "default_behavior": "autonomous",
    "human_gate": "only-when-blocked"
  }
}
