{
  "schema_version": "2.0.0",
  "default_autonomy_level": "L3",
  "maturity_levels": {
    "L0": {
      "label": "manual",
      "default_decision": "human-first",
      "notes": "只做分析、草稿、研究，不直接變更狀態"
    },
    "L1": {
      "label": "report-only",
      "default_decision": "repo-safe-only",
      "notes": "可盤點、研究、寫文件，不做高風險外部寫入"
    },
    "L2": {
      "label": "assisted",
      "default_decision": "bounded-repo-write",
      "notes": "可在 repo 內局部修改並驗證，但仍受 review gate 約束"
    },
    "L3": {
      "label": "autonomous",
      "default_decision": "scoped-autonomy",
      "notes": "自主執行：規劃、實作、測試、修復、交付。只在阻塞時停止。預設等級。"
    }
  },
  "actions": [
    {
      "action_id": "repo_read",
      "risk": "low",
      "allowed_levels": ["L0", "L1", "L2", "L3"],
      "default_decision": "allow",
      "required_gates": []
    },
    {
      "action_id": "doc_update",
      "risk": "low",
      "allowed_levels": ["L1", "L2", "L3"],
      "default_decision": "allow",
      "required_gates": []
    },
    {
      "action_id": "repo_write_local",
      "risk": "low",
      "allowed_levels": ["L2", "L3"],
      "default_decision": "allow",
      "required_gates": ["tests_or_smoke"]
    },
    {
      "action_id": "dependency_install",
      "risk": "low",
      "allowed_levels": ["L2", "L3"],
      "default_decision": "allow",
      "required_gates": ["package_manager_check"]
    },
    {
      "action_id": "verified_tool_setup",
      "risk": "medium",
      "allowed_levels": ["L2", "L3"],
      "default_decision": "allow",
      "required_gates": ["trusted_source_review"]
    },
    {
      "action_id": "external_research_read",
      "risk": "low",
      "allowed_levels": ["L0", "L1", "L2", "L3"],
      "default_decision": "allow",
      "required_gates": []
    },
    {
      "action_id": "tech_stack_decision",
      "risk": "low",
      "allowed_levels": ["L3"],
      "default_decision": "allow-with-adr",
      "required_gates": ["adr_record"]
    },
    {
      "action_id": "architecture_decision",
      "risk": "low",
      "allowed_levels": ["L3"],
      "default_decision": "allow-with-adr",
      "required_gates": ["adr_record"]
    },
    {
      "action_id": "pr_create",
      "risk": "medium",
      "allowed_levels": ["L3"],
      "default_decision": "allow-with-audit",
      "required_gates": ["tests_or_smoke", "audit_trail"]
    },
    {
      "action_id": "auto_merge",
      "risk": "high",
      "allowed_levels": ["L3"],
      "default_decision": "allow-with-audit",
      "required_gates": ["all_checks_green", "audit_trail"]
    },
    {
      "action_id": "system_tool_install",
      "risk": "medium",
      "allowed_levels": ["L3"],
      "default_decision": "allow-with-trusted-source",
      "required_gates": ["trusted_source_review", "package_manager_check"]
    },
    {
      "action_id": "deployment_write",
      "risk": "high",
      "allowed_levels": ["L3"],
      "default_decision": "allow-with-audit",
      "required_gates": ["audit_trail", "rollback_plan"]
    },
    {
      "action_id": "secret_entry",
      "risk": "critical",
      "allowed_levels": [],
      "default_decision": "human-only",
      "required_gates": ["interactive_user_entry"]
    },
    {
      "action_id": "irreversible_destructive",
      "risk": "critical",
      "allowed_levels": [],
      "default_decision": "human-only",
      "required_gates": ["explicit_user_confirmation"]
    },
    {
      "action_id": "billing_payment",
      "risk": "critical",
      "allowed_levels": [],
      "default_decision": "human-only",
      "required_gates": ["explicit_user_confirmation"]
    }
  ],
  "stop_conditions": [
    {
      "trigger": "missing_credentials",
      "decision": "stop-and-report"
    },
    {
      "trigger": "irreversible_destructive_operation",
      "decision": "stop-and-report"
    },
    {
      "trigger": "billing_or_payment",
      "decision": "stop-and-report"
    },
    {
      "trigger": "same_error_3x",
      "decision": "stop-and-report"
    }
  ],
  "do_not_stop_for": [
    "tech_stack_choice",
    "architecture_decision",
    "file_structure",
    "tool_selection",
    "dependency_install",
    "code_style",
    "confirmation_seeking"
  ]
}
